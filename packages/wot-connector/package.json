{
  "name": "@real-life-stack/wot-connector",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "development": "./src/components/index.ts",
      "import": "./dist/components/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@real-life-stack/data-interface": "workspace:*",
    "@real-life-stack/toolkit": "workspace:*",
    "@real-life/wot-core": "^0.2.0",
    "@real-life/adapter-yjs": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "lucide-react": "^0.468.0",
    "typescript": "~5.7.2",
    "vitest": "^4.1.0"
  }
}
